{
  "name": "voice-trainer",
  "version": "0.1.0",
  "description": "Open-source Microsoft Teams app for voice & pronunciation training for non-English speakers",
  "author": "VikrantSingh01",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/VikrantSingh01/voice-trainer.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --config src/client/vite.config.ts",
    "dev:server": "ts-node-dev --respawn --transpile-only src/server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --config src/client/vite.config.ts",
    "build:server": "tsc -p src/server/tsconfig.json",
    "start": "node dist/server/index.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,json,css}'",
    "typecheck": "tsc --noEmit",
    "dev:teamsfx": "npx cross-env NODE_OPTIONS='--inspect=9239' npx env-cmd -f .env npm run dev",
    "dev:teamsfx:testtool": "npx cross-env NODE_OPTIONS='--inspect=9239' npx env-cmd -f .env npm run dev",
    "dev:teamsfx:launch-testtool": "npx env-cmd --silent -f env/.env.testtool teamsapptester start"
  },
  "dependencies": {
    "@fluentui/react-charting": "^5.23.0",
    "@fluentui/react-components": "^9.56.0",
    "@fluentui/react-icons": "^2.0.258",
    "@microsoft/teams-js": "^2.31.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.42.0",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@microsoft/teamsapp-cli": "^3.0.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "eslint": "^9.15.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "env-cmd": "latest"
  }
}
