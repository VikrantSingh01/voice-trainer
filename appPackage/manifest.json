{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.19/MicrosoftTeams.schema.json",
  "manifestVersion": "1.19",
  "version": "0.1.0",
  "id": "${{TEAMS_APP_ID}}",
  "developer": {
    "name": "Voice Trainer OSS",
    "websiteUrl": "https://github.com/VikrantSingh01/voice-trainer",
    "privacyUrl": "https://github.com/VikrantSingh01/voice-trainer/blob/main/PRIVACY.md",
    "termsOfUseUrl": "https://github.com/VikrantSingh01/voice-trainer/blob/main/LICENSE"
  },
  "name": {
    "short": "Voice Trainer${{APP_NAME_SUFFIX}}",
    "full": "Voice Trainer - Pronunciation Training for Non-English Speakers"
  },
  "description": {
    "short": "Practice English pronunciation with AI-powered feedback",
    "full": "Voice Trainer helps non-English speakers improve their English pronunciation through real-time AI feedback, guided lessons, progress tracking, and interactive conversation practice. Powered by Azure Speech SDK and Azure OpenAI."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#4F6BED",
  "staticTabs": [
    {
      "entityId": "practice",
      "name": "Practice",
      "contentUrl": "${{BOT_ENDPOINT}}/index.html#/practice",
      "scopes": ["personal"]
    },
    {
      "entityId": "lessons",
      "name": "Lessons",
      "contentUrl": "${{BOT_ENDPOINT}}/index.html#/lessons",
      "scopes": ["personal"]
    },
    {
      "entityId": "conversation",
      "name": "Conversation",
      "contentUrl": "${{BOT_ENDPOINT}}/index.html#/conversation",
      "scopes": ["personal"]
    },
    {
      "entityId": "dashboard",
      "name": "Dashboard",
      "contentUrl": "${{BOT_ENDPOINT}}/index.html#/dashboard",
      "scopes": ["personal"]
    }
  ],
  "permissions": ["identity"],
  "validDomains": ["${{BOT_DOMAIN}}"],
  "webApplicationInfo": {
    "id": "${{BOT_ID}}",
    "resource": "api://${{BOT_DOMAIN}}/${{BOT_ID}}"
  }
}
