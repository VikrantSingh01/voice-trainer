# Azure Speech Service
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastus

# Azure OpenAI Service
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Teams App
TAB_DOMAIN=localhost:3000
TAB_ENDPOINT=https://localhost:3000
AAD_APP_CLIENT_ID=your-aad-client-id

# Server
PORT=3001
NODE_ENV=development

# Set to "true" to skip real Azure services and use built-in mock responses.
# Useful for local dev when Azure OpenAI deployment is not yet provisioned.
USE_MOCK_SERVICES=true
